import pandas as pd

file_path = '/home/won/beam_balance_rear-won-2026-03-16/videos/results_v2/00250DLC_resnet50_beam_balance_rearMar16shuffle1_20000.csv'

df = pd.read_csv(file_path, header=[0, 1, 2], index_col=0)
df.columns = df.columns.droplevel(0)


fps = 30              # 영상의 초당 프레임 수
start_line_y = 800    # 타이머 시작 기준선
end_line_y = 550      # 타이머 종료 기준선
window_size = 30      # 노이즈 제거용 필터 크기 (30프레임 = 0.1초)

y_mean = df[[('left', 'y'), ('right', 'y')]].mean(axis=1)

y_smooth = y_mean.rolling(window=window_size, center=True, min_periods=1).median()

# 3. 부드러워진 궤적을 바탕으로 출발선/도착선 통과 지점 찾기
start_frames = y_smooth[y_smooth <= start_line_y].index
end_frames = y_smooth[y_smooth <= end_line_y].index

if len(start_frames) > 0 and len(end_frames) > 0:
    start_frame = start_frames[0]
    
    # 도착 프레임은 반드시 출발 프레임 이후여야 함
    valid_end_frames = end_frames[end_frames > start_frame]
    
    if len(valid_end_frames) > 0:
        end_frame = valid_end_frames[0]
        
        # 총 소요 프레임 및 시간 계산
        total_frames = end_frame - start_frame
        traverse_time = total_frames / fps
        
        print("📊 [빔 밸런스 도착 시간 분석 결과]")
        print(f"▶ 출발선 (Y={start_line_y}) 통과 프레임: {start_frame}")
        print(f"▶ 도착선 (Y={end_line_y}) 통과 프레임: {end_frame}")
        print(f"▶ 총 이동 프레임: {total_frames} frames")
        print("-" * 30)
        print(f"⏱️ 최종 구간(800->550) 통과 소요 시간: {traverse_time:.2f} 초")
    else:
        print("❌ 쥐가 출발선은 넘었으나 도착선(Y=410)을 완전히 통과하지 못했습니다.")
else:
    print("❌ 쥐가 출발선(Y=800)을 넘지 않았거나 화면에 인식되지 않았습니다.")

