import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import os
from sklearn.metrics import r2_score # R-squared 계산용

file_path = '/home/won/beam_balance_rear-won-2026-03-16/videos/results_v2/Hetero 1DLC_resnet50_beam_balance_rearMar16shuffle1_20000.csv'

save_dir = '/home/won/beam_balance_rear-won-2026-03-16/figure'
os.makedirs(save_dir, exist_ok=True)
save_filename = os.path.join(save_dir, 'Hetero 1_Scatter_with_Stats.png')

df = pd.read_csv(file_path, header=[0, 1, 2], index_col=0)
df.columns = df.columns.droplevel(0)

p_cutoff = 0.6 
ci_margin = 50

plt.figure(figsize=(11, 8))

for paw, color, line_color in [('left', 'blueviolet', 'darkblue'), ('right', 'red', 'darkred')]:
    valid = df[(paw, 'likelihood')] > p_cutoff
    x = df.loc[valid, (paw, 'x')].dropna().values
    y = df.loc[valid, (paw, 'y')].dropna().values
    
    # ① 선형 회귀 및 R-squared 계산
    slope, intercept = np.polyfit(x, y, 1)
    y_pred = slope * x + intercept
    r_squared = r2_score(y, y_pred) # 결정계수 계산
    
    # 추세선 그리기용 데이터
    line_x = np.linspace(x.min(), x.max(), 100)
    line_y = slope * line_x + intercept
    
    # ② 그래프 그리기
    # 범례에 R² 값을 포함시킵니다.
    label_txt = f'{paw} (Slope: {slope:.2f}, $R^2$: {r_squared:.3f})'
    
    plt.fill_between(line_x, line_y - ci_margin, line_y + ci_margin, 
                     color=color, alpha=0.15, label=f'{paw} CI ($\pm${ci_margin}px)')
    
    plt.plot(line_x, line_y, color=line_color, linewidth=2, linestyle='--', label=f'{paw} Trend')
    
    plt.scatter(x, y, color=color, s=15, alpha=0.6, label=label_txt)

plt.xlabel('X position (pixels)', fontsize=12)
plt.ylabel('Y position (pixels)', fontsize=12)
plt.ylim(1000, 300)

plt.legend(bbox_to_anchor=(1.02, 1), loc='upper left', fontsize=10)
plt.title('Hetero: Paw Trajectory Analysis', fontsize=15)

plt.tight_layout()
plt.savefig(save_filename, dpi=300, bbox_inches='tight')
print(f"✅ 통계 수치가 포함된 그래프가 저장되었습니다: {save_filename}")
plt.show()

