import pandas as pd
import numpy as np

file_path = '/home/won/beam_balance_rear-won-2026-03-16/videos/results_v2/00280DLC_resnet50_beam_balance_rearMar16shuffle1_20000.csv'

df = pd.read_csv(file_path, header=[0, 1, 2], index_col=0)
df.columns = df.columns.droplevel(0)

# ---------------------------------------------------------
p_cutoff = 0.3
slip_margin = 50       # 쥐의 실시간 보행 궤적보다 '50px' 이상 밑으로 떨어지면 Slip!
min_frames = 2         # 최소 2프레임(0.1초) 이상 유지되어야 인정
window_size = 30       # 실시간 기준선을 만들 때 참고할 앞뒤 프레임 수 (30프레임 = 약 1초)
# ---------------------------------------------------------

print(f"🔍 [Rolling Baseline 기반 Slip 분석 결과]")
print(f"기준 1: 실시간 예상 궤적보다 {slip_margin}px 이상 하락 시")
print(f"기준 2: 보행 중 포인트 소실 시 (완전 빠짐)\n")

total_slips = 0

active_frames = df[(df[('left', 'likelihood')] > p_cutoff) | (df[('right', 'likelihood')] > p_cutoff)].index

if len(active_frames) > 0:
    start_frame = active_frames[0]
    end_frame = active_frames[-1]
    walk_df = df.loc[start_frame:end_frame].copy()
    
    for paw in ['left', 'right']:
        y_raw = walk_df[(paw, 'y')].copy()
        likelihood = walk_df[(paw, 'likelihood')].copy()
        
        # 1. 신뢰할 수 없는 점(완전히 빠진 점)을 빈칸(NaN)으로 만들기
        y_trusted = y_raw.copy()
        y_trusted[likelihood <= p_cutoff] = np.nan
        
        # 2. 빈칸을 앞뒤 데이터를 보고 자연스럽게 이어주기 (Interpolation)
        y_interp = y_trusted.interpolate(method='linear', limit_direction='both')
        
        # 3. [핵심] 1초 단위로 평균적인 걷기 높이(가상의 빔) 계산하기
        # 쥐가 앞으로 전진함에 따라 기준선(y_baseline)도 자연스럽게 변화합니다.
        y_baseline = y_interp.rolling(window=window_size, center=True, min_periods=1).median()
        
        # [조건 1] 찍힌 점 중에서, 가상 빔보다 밑으로 훅 떨어진 경우
        cond1_visible = (likelihood > p_cutoff) & (y_raw > (y_baseline + slip_margin))
        
        # [조건 2] 걷는 와중에 발이 안 찍힌 경우 (빔 밑으로 가려짐)
        cond2_invisible = (likelihood <= p_cutoff)
        
        is_slip = cond1_visible | cond2_invisible
        
        # 연속 프레임 묶기
        blocks = (is_slip != is_slip.shift(1)).cumsum()
        slip_events = is_slip.groupby(blocks).sum()
        
        # 실제 횟수 카운트
        actual_slip_count = (slip_events >= min_frames).sum()
        total_slips += actual_slip_count
        
        print(f"🐾 {paw.capitalize()} Paw (발): {actual_slip_count} 회")

else:
    print("❌ 화면에 쥐가 인식된 프레임이 없습니다.")

print("-" * 45)
print(f"총 Slip 횟수 (Left + Right): {total_slips} 회")

