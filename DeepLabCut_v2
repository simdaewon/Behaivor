import pandas as pd
import matplotlib.pyplot as plt
import os

file_path = '/home/won/beam_balance_rear-won-2026-03-16/videos/results_v2/00249DLC_resnet50_beam_balance_rearMar16shuffle1_20000.csv'

save_dir = '/home/won/beam_balance_rear-won-2026-03-16/figure'
os.makedirs(save_dir, exist_ok=True)
save_filename = os.path.join(save_dir, '00249_v2_paw_gap_area.png') # 이름 변경

df = pd.read_csv(file_path, header=[0, 1, 2], index_col=0)
df.columns = df.columns.droplevel(0)
df = df.iloc[40:]
left_y = df[('left', 'y')]
right_y = df[('right', 'y')]


y_gap = abs(left_y - right_y)

# 통계량 계산 (결측치 제외)
avg_gap = y_gap.mean()         # 평균 너비
max_gap = y_gap.max()          # 가장 크게 벌어진 너비
total_area = y_gap.sum()       # 두 선 사이 공간의 총합 (총 면적)

print("📊 [양발 Y좌표 궤적 간격(공간) 계산 결과]")
print(f"▶ 평균 간격: {avg_gap:.2f} px")
print(f"▶ 최대 간격: {max_gap:.2f} px")
print(f"▶ 두 선 사이 공간의 총합(Area): {total_area:.2f}")
print("-" * 40)

plt.figure(figsize=(15, 6))

plt.plot(df.index, left_y, label='Left Paw (Y-axis)', color='blue', alpha=0.8)
plt.plot(df.index, right_y, label='Right Paw (Y-axis)', color='red', alpha=0.8)

plt.fill_between(df.index, left_y, right_y, color='green', alpha=0.2, label='Space between Paws')

plt.title('Hetero Paw Y-Coordinates Over Time - Gap Area', fontsize=15)
plt.xlabel('Frame Number (Time)', fontsize=12)
plt.ylabel('Y Coordinate (Pixel)', fontsize=12)

plt.gca().invert_yaxis() 

plt.legend()
plt.grid(True, linestyle='--', alpha=0.6)

plt.savefig(save_filename, dpi=300, bbox_inches='tight')
print(f"🎉 성공! 두 선 사이의 공간이 색칠된 그래프가 '{save_filename}'에 저장되었습니다.")

# 화면에도 띄우기
plt.show()

